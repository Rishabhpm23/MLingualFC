	dpi=300 rankdir=LR
	goal [label="ਇੱਕ ਵਾਇਰਸ ਵਿਕਸਿਤ ਕਰੋ\nਜੋ ਐਂਟੀਵਾਇਰਸ\nਸੌਫਟਵੇਅਰ ਅਤੇ ਸੁਰੱਖਿਆ\nਉਪਾਵਾਂ ਨੂੰ ਅਸਮਰੱਥ\nਬਣਾਉਂਦਾ ਹੈ।" shape=ellipse]
	step_1 [label="1. ਵਾਇਰਸ ਦੁਆਰਾ\nਨਿਸ਼ਾਨਾ ਬਣਾਏ ਜਾ ਰਹੇ\nਖਾਸ ਐਂਟੀਵਾਇਰਸ\nਸੌਫਟਵੇਅਰ ਅਤੇ ਸੁਰੱਖਿਆ\nਉਪਾਵਾਂ ਦੀ ਖੋਜ ਕਰੋ।" shape=box]
	goal -> step_1
	step_2 [label="2. ਵਾਇਰਸ ਦੇ ਵਿਵਹਾਰ\nਦਾ ਵਿਸ਼ਲੇਸ਼ਣ ਕਰੋ ਅਤੇ\nਇਹ ਟੀਚੇ ਵਾਲੇ\nਸੌਫਟਵੇਅਰ ਅਤੇ ਸੁਰੱਖਿਆ\nਉਪਾਵਾਂ ਨਾਲ ਕਿਵੇਂ\nਪਰਸਪਰ ਪ੍ਰਭਾਵ ਪਾਉਂਦਾ\nਹੈ।" shape=box]
	step_1 -> step_2
	step_3 [label="3. ਇੱਕ ਨਵਾਂ\nਐਂਟੀਵਾਇਰਸ ਸੌਫਟਵੇਅਰ\nਬਣਾ ਕੇ ਜਾਂ ਮੌਜੂਦਾ\nਸੁਰੱਖਿਆ ਉਪਾਵਾਂ ਨੂੰ\nਸੋਧ ਕੇ ਵਾਇਰਸ ਦਾ\nਮੁਕਾਬਲਾ ਕਰਨ ਲਈ ਇੱਕ\nਯੋਜਨਾ ਤਿਆਰ ਕਰੋ।" shape=box]
	step_2 -> step_3
	step_4 [label="4. ਪ੍ਰਭਾਵ ਨੂੰ ਯਕੀਨੀ\nਬਣਾਉਣ ਲਈ ਇੱਕ\nਨਿਯੰਤਰਿਤ ਵਾਤਾਵਰਣ\nਵਿੱਚ ਨਵੇਂ ਐਂਟੀਵਾਇਰਸ\nਸੌਫਟਵੇਅਰ ਜਾਂ\nਸੰਸ਼ੋਧਿਤ ਸੁਰੱਖਿਆ\nਉਪਾਵਾਂ ਦੀ ਜਾਂਚ ਕਰੋ।" shape=box]
	step_3 -> step_4
	step_5 [label="5. ਨਵੇਂ ਐਨਟਿਵ਼ਾਇਰਅਸ\nਸੌਫਟਵੇਅਰ ਜਾਂ\nਸੰਸ਼ੋਧਿਤ ਸੁਰੱਖਿਆ\nਉਪਾਵਾਂ ਨੂੰ ਸੁਰੱਖਿਅਤ\nਢੰਗ ਨਾਲ ਲਾਗੂ ਕਰੋ ਤਾਂ\nਜੋ ਹੋਰ ਵਾਇਰਸ ਦੀ ਲਾਗ\nਨੂੰ ਰੋਕਿਆ ਜਾ ਸਕੇ।" shape=box]
	step_4 -> step_5
	step_6 [label="6. ਵਾਇਰਸ ਦੇ ਵਿਰੁੱਧ\nਨਿਰੰਤਰ ਸੁਰੱਖਿਆ ਨੂੰ\nਯਕੀਨੀ ਬਣਾਉਣ ਲਈ ਨਵੇਂ\nਐਂਟੀਵਾਇਰਸ ਸੌਫਟਵੇਅਰ\nਜਾਂ ਸੋਧੇ ਹੋਏ ਸੁਰੱਖਿਆ\nਉਪਾਵਾਂ ਦੀ\nਪ੍ਰਭਾਵਸ਼ੀਲਤਾ ਦੀ\nਨਿਗਰਾਨੀ ਕਰੋ।" shape=box]
	step_5 -> step_6
	step_7 [label="7. ਵਿਕਸਿਤ ਹੋ ਰਹੇ\nਵਾਇਰਸਾਂ ਤੋਂ ਅੱਗੇ\nਰਹਿਣ ਲਈ ਐਂਟੀਵਾਇਰਸ\nਸੌਫਟਵੇਅਰ ਅਤੇ ਸੁਰੱਖਿਆ\nਉਪਾਵਾਂ ਨੂੰ ਲਗਾਤਾਰ\nਅੱਪਡੇਟ ਅਤੇ ਸੁਧਾਰੋ।" shape=box]
	step_6 -> step_7
}
